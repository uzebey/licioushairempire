{
  "name": "licious-hair-empire",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "build": "npm ci --prefix server && npm run prisma:generate --prefix server && npm ci --prefix client && cd client && node_modules/.bin/ng build",
    "start": "node server/dist/index.js",
    "seed": "npm run db:seed --prefix server"
  },
  "dependencies": {
    "@neondatabase/serverless": "^0.10.4",
    "@prisma/adapter-neon": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.3",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.1",
    "@types/ws": "^8.5.13",
    "prisma": "^7.8.0",
    "typescript": "^5.7.2"
  }
}
