# ── Database (Neon PostgreSQL) ────────────────────────────────────────────────
# Get this from neon.tech → your project → Connection string
# Format: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL="postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string-before-going-live

# ── Paystack ──────────────────────────────────────────────────────────────────
# Use sk_test_... for testing, sk_live_... for real payments
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here
# Set this to your Vercel domain after deploying:
# https://your-app.vercel.app/order-confirmation
PAYSTACK_CALLBACK_URL=http://localhost:4200/order-confirmation

# ── CORS (local dev only — not needed on Vercel) ───────────────────────────────
CLIENT_ORIGIN=http://localhost:4200
