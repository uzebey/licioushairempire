# ── Server ───────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ── Database (SQLite) ─────────────────────────────────────────────────────────
# On Railway: mount a volume at /data and set this to file:/data/licious.db
DATABASE_URL="file:./prisma/dev.db"

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-string-before-going-live

# ── Paystack ──────────────────────────────────────────────────────────────────
# Use sk_test_... for testing, sk_live_... for production payments
PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key_here
# Set this to your Railway domain after deploying, e.g.:
# https://licioushairempire-production.up.railway.app/order-confirmation
PAYSTACK_CALLBACK_URL=http://localhost:4200/order-confirmation

# ── CORS (dev only — not needed in production) ────────────────────────────────
CLIENT_ORIGIN=http://localhost:4200
